# ==================== 数据库 ====================
MYSQL_HOST=mysql-master
MYSQL_PORT=3308
MYSQL_DATABASE=vnollxonlinejudge
MYSQL_ROOT_PASSWORD=your_mysql_password

# ==================== Redis ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ==================== RabbitMQ ====================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=your_rabbitmq_password

# ==================== MinIO ====================
MINIO_PRIMARY_URL=http://primary-minio:9000
MINIO_PRIMARY_ACCESS_KEY=your_minio_access_key
MINIO_PRIMARY_SECRET_KEY=your_minio_secret_key
MINIO_SECONDARY_URL=http://secondary-minio:9000
MINIO_SECONDARY_ACCESS_KEY=your_minio_access_key
MINIO_SECONDARY_SECRET_KEY=your_minio_secret_key
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password

# ==================== 邮件 ====================
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_email_auth_code

# ==================== Judge Agent ====================
JUDGE_AGENT_REMOTE_ENDPOINT=http://remote-judge-agent:8090
JUDGE_AGENT_REMOTE_CAPACITY=8
JUDGE_AGENT_LOCAL_ENDPOINT=http://local-judge-agent:8090
JUDGE_AGENT_LOCAL_CAPACITY=2

# ==================== AI 代理 ====================
AI_PROXY_DOMESTIC_URL=http://ai-proxy:8000
AI_PROXY_OVERSEAS_URL=http://ai-proxy:8000
AI_PROXY_TIMEOUT=300
